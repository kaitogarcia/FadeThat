# Public base URL for the backend API used by the frontend.
# Local FastAPI default:
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Railway example:
# NEXT_PUBLIC_API_BASE_URL=https://<your-railway-service>.up.railway.app

# Optional server-side API proxy target for Next.js rewrites.
# If set, requests to /api/* on the web app are proxied to this backend.
# API_BASE_URL=http://localhost:8000
