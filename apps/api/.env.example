# Comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS=http://localhost:3000

# Public URL that Meta's Graph API can reach for uploaded images.
# In Railway production this should be your backend public domain.
INSTAGRAM_PUBLIC_BASE_URL=http://localhost:8000

# Delay between each publish during mass post jobs.
INSTAGRAM_POST_BUFFER_SECONDS=10

# Special Instagram login token used when users enter "hey" or "baby" in /instagram.
# Set this in Railway for the API service.
# FADE_THAT_TOKEN=EAAB...

# Optional override for board notes SQLite path.
# Default (if unset): apps/api/runtime/board.db
# BOARD_DB_PATH=/data/board.db
