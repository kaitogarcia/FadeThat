{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/optin", "destination": "/optin/index.html" },
    { "source": "/tooling", "destination": "/tooling/index.html" },
    { "source": "/scraper", "destination": "/scraper/index.html" },
    { "source": "/privacy", "destination": "/privacy/index.html" },
    { "source": "/terms", "destination": "/terms/index.html" }
  ]
}
